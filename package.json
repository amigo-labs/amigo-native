{
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "build:debug": "pnpm -r run build:debug",
    "test": "pnpm -r run test",
    "test:parity": "node scripts/parity-report.mjs",
    "test:conformance": "pnpm -r run test:conformance",
    "test:conformance:summary": "node scripts/conformance-summary.mjs",
    "bench": "vitest bench",
    "bench:size": "node scripts/measure-size.mjs",
    "build:readmes": "node scripts/render-readmes.mjs",
    "bench:report": "node scripts/run-benchmarks.mjs && node scripts/measure-size.mjs && node scripts/parity-report.mjs && node scripts/render-readmes.mjs && node scripts/generate-report.mjs",
    "lint": "oxlint --ignore-pattern 'crates/sanitize-html/__conformance__/upstream/**' . && cargo fmt --check && cargo clippy --workspace -- -D warnings",
    "format": "prettier --write . && cargo fmt && taplo format",
    "deploy:dry": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/adm-zip": "^0.5.7",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/papaparse": "^5.3.15",
    "@types/sanitize-html": "^2.13.0",
    "@types/sax": "^1.2.7",
    "@types/yauzl": "^2.10.3",
    "adm-zip": "^0.5.16",
    "argon2": "^0.44.0",
    "csv-parse": "^5.6.0",
    "deepmerge": "^4.3.1",
    "fast-levenshtein": "^3.0.0",
    "file-type": "^19.6.0",
    "gpt-tokenizer": "^3.0.0",
    "hash-wasm": "^4.11.0",
    "iconv-lite": "^0.7.2",
    "isomorphic-dompurify": "^3.11.0",
    "js-tiktoken": "^1.0.21",
    "jsonwebtoken": "^9.0.2",
    "leven": "^4.0.0",
    "nanoid": "^5.0.9",
    "oxlint": "^1.62.0",
    "pako": "^2.1.0",
    "papaparse": "^5.4.1",
    "prettier": "^3.8.3",
    "sanitize-html": "^2.17.3",
    "sax": "^1.4.1",
    "slugify": "^1.6.6",
    "tiktoken": "^1.0.21",
    "vitest": "^4.1.5",
    "wrangler": "^4.40.0",
    "xxhash-wasm": "^1.1.0",
    "xxhashjs": "^0.2.2",
    "yauzl": "^3.2.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">= 22"
  }
}
