{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "@data/*": ["../docs/*"]
    },
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false
  }
}
