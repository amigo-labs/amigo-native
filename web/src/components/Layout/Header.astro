---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle";
import MobileDrawer from "./MobileDrawer";
import { brand } from "~/lib/packages";

const nav = [
  { label: "Packages", href: "/" },
  { label: "Getting started", href: "/getting-started" },
  { label: "Changelog", href: "/changelog" },
  { label: "Perf review", href: "/perf-review" },
];

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";

function isCurrent(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header
  class="sticky top-0 z-40 border-b border-line bg-bg/95 backdrop-blur-md supports-[backdrop-filter]:bg-bg/85"
>
  <div
    class="mx-auto flex h-(--header-h) max-w-(--container) items-center gap-4 px-4 sm:px-6 lg:px-8"
  >
    <a
      href="/"
      class="flex items-center gap-2 font-mono text-sm font-medium tracking-(--tracking-snug) text-fg hover:text-accent transition-colors"
      aria-label={`${brand.name} home`}
    >
      <Logo size={28} />
      <span class="hidden sm:inline">
        {brand.name.split("-")[0]}<span class="text-accent">-{brand.name.split("-")[1]}</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          aria-current={isCurrent(item.href) ? "page" : undefined}
          class:list={[
            "rounded-md px-3 py-1.5 text-sm transition-colors",
            isCurrent(item.href)
              ? "text-fg bg-bg-elevated"
              : "text-fg-muted hover:text-fg hover:bg-bg-elevated",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="ms-auto flex items-center gap-2">
      <a
        href={brand.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex h-9 items-center gap-2 rounded-md border border-line bg-bg-elevated px-3 text-sm text-fg-muted hover:border-line-strong hover:text-fg transition-colors"
        aria-label={`${brand.name} repository on GitHub`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="14"
          height="14"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12 .5A11.5 11.5 0 0 0 .5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.55v-2.04c-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.69.08-.69 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.69 1.24 3.34.95.1-.74.4-1.24.72-1.52-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.73.8 1.18 1.83 1.18 3.09 0 4.43-2.69 5.4-5.26 5.69.41.36.78 1.06.78 2.13v3.16c0 .31.21.66.79.55A11.5 11.5 0 0 0 23.5 12 11.5 11.5 0 0 0 12 .5z" />
        </svg>
        GitHub
      </a>
      <ThemeToggle client:load />
      <MobileDrawer client:idle nav={nav} repoUrl={brand.repoUrl} currentPath={currentPath} />
    </div>
  </div>
</header>
