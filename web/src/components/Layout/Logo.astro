---
interface Props {
  /** Visual size in px, applied to both width and height. */
  size?: number;
  class?: string;
}

const { size = 28, class: className = "" } = Astro.props;
---

<img
  src="/logo.png"
  alt=""
  aria-hidden="true"
  width={size}
  height={size}
  class:list={["shrink-0 select-none", className]}
  style={`width: ${size}px; height: ${size}px;`}
  decoding="async"
  loading="eager"
/>
