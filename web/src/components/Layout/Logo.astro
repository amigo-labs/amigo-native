---
interface Props {
  /** Visual size in px, applied to both width and height. */
  size?: number;
  class?: string;
}

const { size = 22, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 32 32"
  width={size}
  height={size}
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  stroke-linejoin="round"
  stroke-width="2"
  aria-hidden="true"
  class={className}
>
  <path d="M5 25 L16 6 L27 25 Z" fill="var(--accent-dim)" />
  <circle cx="16" cy="19" r="3.5" fill="var(--accent)" stroke="none" />
</svg>
