---
import Base from "~/layouts/Base.astro";
---

<Base
  title="Changelog"
  description="Releases, deprecations, and perf-review verdict changes across all amigo-native packages."
>
  <div class="mx-auto max-w-3xl pt-10 pb-16">
    <h1 class="text-3xl font-semibold tracking-(--tracking-tight)">
      Changelog
    </h1>
    <p class="mt-3 text-lg text-fg-muted">
      Phase 1 placeholder. The timeline lands in phase 5, fed from npm
      release tags (<code class="font-mono text-sm">.release-please-manifest.json</code> +
      git tags) and the post-mortems under <code class="font-mono text-sm">docs/post-mortems/</code>.
    </p>
  </div>
</Base>
