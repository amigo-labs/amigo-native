---
import Base from "~/layouts/Base.astro";
import { packages, type Pkg } from "~/lib/packages";

export function getStaticPaths() {
  return packages.map((pkg) => ({
    params: { slug: pkg.name },
    props: { pkg },
  }));
}

interface Props {
  pkg: Pkg;
}

const { pkg } = Astro.props;
---

<Base title={pkg.title} description={pkg.description}>
  <nav class="pt-8 pb-4 text-xs font-mono text-fg-subtle" aria-label="Breadcrumb">
    <a href="/" class="hover:text-fg">Packages</a>
    <span class="mx-1">/</span>
    <span class="text-fg">{pkg.name}</span>
  </nav>

  <section class="pb-8">
    <div class="flex flex-wrap items-baseline gap-3">
      <h1 class="text-3xl font-semibold tracking-(--tracking-tight)">
        {pkg.title}
      </h1>
      <span class="font-mono text-xs uppercase tracking-(--tracking-wide) text-fg-subtle">
        {pkg.category}
      </span>
      <span class="font-mono text-sm text-accent">{pkg.speedup}</span>
    </div>
    <p class="mt-3 max-w-2xl text-lg text-fg-muted">{pkg.description}</p>
  </section>

  <section
    id="install"
    aria-labelledby="install-h"
    class="mb-8 rounded-xl border border-line bg-bg-elevated p-4"
  >
    <h2 id="install-h" class="mb-3 font-mono text-xs uppercase tracking-(--tracking-wide) text-fg-subtle">
      Install
    </h2>
    <pre
      class="overflow-x-auto rounded-md border border-line bg-bg-sunken px-3 py-2 font-mono text-sm"
    ><code>pnpm add @amigo-labs/{pkg.name}</code></pre>
  </section>

  <section class="grid gap-3 sm:grid-cols-3 mb-12">
    <a
      href={pkg.npmUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-xl border border-line bg-bg-elevated p-4 hover:border-line-strong transition-colors"
    >
      <div class="font-mono text-xs uppercase tracking-(--tracking-wide) text-fg-subtle">
        npm
      </div>
      <div class="mt-1 text-sm text-fg">View on npm →</div>
    </a>
    <a
      href={pkg.sourceUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-xl border border-line bg-bg-elevated p-4 hover:border-line-strong transition-colors"
    >
      <div class="font-mono text-xs uppercase tracking-(--tracking-wide) text-fg-subtle">
        source
      </div>
      <div class="mt-1 text-sm text-fg">View crate source →</div>
    </a>
    {pkg.readmeUrl && (
      <a
        href={pkg.readmeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-xl border border-line bg-bg-elevated p-4 hover:border-line-strong transition-colors"
      >
        <div class="font-mono text-xs uppercase tracking-(--tracking-wide) text-fg-subtle">
          readme
        </div>
        <div class="mt-1 text-sm text-fg">Read the docs →</div>
      </a>
    )}
  </section>

  <p class="text-xs text-fg-subtle">
    Phase 1 scaffolding. Benchmarks chart, footprint, embedded README,
    perf-review section, post-mortem, and related packages arrive in
    phase 3.
  </p>
</Base>
