---
import Base from "~/layouts/Base.astro";
---

<Base title="Not found" description="Page not found.">
  <section class="flex min-h-[60vh] flex-col items-center justify-center text-center">
    <div
      class="font-mono text-xs uppercase tracking-(--tracking-wide) text-fg-subtle"
    >
      404
    </div>
    <h1
      class="mt-4 text-3xl font-semibold tracking-(--tracking-tight)"
    >
      Page not found
    </h1>
    <p class="mt-3 max-w-md text-fg-muted">
      The page you're looking for has moved or never existed. Head back to the
      package catalog.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex h-11 items-center rounded-md bg-accent px-5 text-sm font-semibold text-accent-on hover:bg-accent-hot transition-colors"
    >
      ← Back to packages
    </a>
  </section>
</Base>
