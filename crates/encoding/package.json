{
  "name": "@amigo-labs/encoding",
  "version": "0.3.0",
  "description": "Rust-powered character-encoding conversion via encoding_rs",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_encoding_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_encoding_wasm.d.ts",
        "default": "./wasm/pkg/amigo_encoding_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "native.cjs",
    "native.d.ts",
    "README.md",
    "wasm/pkg/amigo_encoding_wasm.js",
    "wasm/pkg/amigo_encoding_wasm_bg.js",
    "wasm/pkg/amigo_encoding_wasm_bg.wasm",
    "wasm/pkg/amigo_encoding_wasm.d.ts",
    "wasm/pkg/amigo_encoding_wasm_bg.wasm.d.ts"
  ],
  "keywords": [
    "encoding",
    "iconv",
    "iconv-lite",
    "charset",
    "native",
    "rust",
    "napi"
  ],
  "napi": {
    "binaryName": "encoding",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --js native.cjs --dts native.d.ts",
    "build:debug": "napi build --platform --js native.cjs --dts native.d.ts",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg && node -e \"require('node:fs').rmSync('pkg/.gitignore',{force:true})\"",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "bench": "vitest bench",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "test:upstream": "vitest run __conformance__/upstream.spec.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^4.8.0",
    "iconv-lite": "^0.7.2",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/encoding"
  },
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "Encoding",
    "category": "text",
    "description": "Character encoding conversion powered by Mozilla's encoding_rs.",
    "tableDescription": "Character encoding via `encoding_rs`",
    "replaces": "iconv-lite",
    "vsJs": "0.61-32x",
    "parity": "100%",
    "status": "Alternative",
    "targets": [
      "node",
      "browser"
    ],
    "competitors": [
      "iconv-lite@0.6.3"
    ]
  }
}
