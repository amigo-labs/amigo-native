{
  "name": "@amigo-labs/sanitize-html",
  "version": "0.1.0",
  "description": "Blazing fast HTML sanitization powered by Rust (ammonia)",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./compat": {
      "types": "./compat.d.ts",
      "default": "./compat.mjs"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "compat.mjs",
    "compat.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "sanitize-html",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "dependencies": {
    "htmlparser2": "^10.0.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "fast-check": "^3.23.0",
    "isomorphic-dompurify": "^2.16.0",
    "sanitize-html": "^2.13.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/sanitize-html"
  },
  "keywords": [
    "sanitize",
    "html",
    "xss",
    "security",
    "native",
    "rust",
    "napi",
    "ammonia"
  ],
  "engines": {
    "node": ">= 18"
  }
}