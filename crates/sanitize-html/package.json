{
  "name": "@amigo-labs/sanitize-html",
  "version": "0.2.1",
  "description": "Blazing fast native HTML sanitizer powered by Rust and html5ever",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_sanitize_html_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_sanitize_html_wasm.d.ts",
        "default": "./wasm/pkg/amigo_sanitize_html_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./compat": {
      "types": "./compat.d.ts",
      "default": "./compat.mjs"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "compat.mjs",
    "compat.d.ts",
    "README.md",
    "wasm/pkg/amigo_sanitize_html_wasm.js",
    "wasm/pkg/amigo_sanitize_html_wasm_bg.js",
    "wasm/pkg/amigo_sanitize_html_wasm_bg.wasm",
    "wasm/pkg/amigo_sanitize_html_wasm.d.ts",
    "wasm/pkg/amigo_sanitize_html_wasm_bg.wasm.d.ts"
  ],
  "napi": {
    "binaryName": "sanitize-html",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "dependencies": {
    "htmlparser2": "^12.0.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0",
    "fast-check": "^4.8.0",
    "isomorphic-dompurify": "^3.16.0",
    "sanitize-html": "^2.17.4",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/sanitize-html"
  },
  "keywords": [
    "sanitize",
    "html",
    "xss",
    "security",
    "native",
    "rust",
    "napi",
    "html5ever"
  ],
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "Sanitize HTML",
    "category": "text",
    "description": "HTML sanitization via Mozilla's ammonia engine.",
    "tableDescription": "HTML sanitization via Mozilla's `ammonia`",
    "replaces": "sanitize-html",
    "vsJs": "1.65-3.8x",
    "parity": "—",
    "status": "Compatible",
    "targets": ["node", "browser"],
    "competitors": [
      "sanitize-html@2.17.0",
      "isomorphic-dompurify@2.16.0"
    ]
  }
}
