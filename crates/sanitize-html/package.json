{
  "name": "@amigo-labs/sanitize-html",
  "version": "0.1.0",
  "description": "Blazing fast HTML sanitization powered by Rust (ammonia)",
  "main": "index.js",
  "types": "index.d.ts",
  "files": ["index.js", "index.d.ts"],
  "napi": {
    "binaryName": "sanitize-html",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish --skip-gh-release",
    "test": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/sanitize-html"
  },
  "keywords": ["sanitize", "html", "xss", "security", "native", "rust", "napi", "ammonia"],
  "engines": { "node": ">= 18" }
}
