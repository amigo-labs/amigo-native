{
  "name": "@amigo-labs/argon2",
  "version": "0.1.0",
  "description": "Fast Argon2id password hashing powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "argon2",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "argon2": "^0.41.1",
    "fast-check": "^3.23.0",
    "hash-wasm": "^4.11.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/argon2"
  },
  "keywords": [
    "argon2",
    "argon2id",
    "password",
    "hashing",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "amigo": {
    "title": "Argon2",
    "description": "Argon2id password hashing with sync + async API.",
    "tableDescription": "Argon2id password hashing (sync + async)",
    "replaces": "argon2/hash-wasm",
    "vsJs": "1.4-2x",
    "parity": "—",
    "status": "Drop-in",
    "competitors": ["argon2@0.41.1", "hash-wasm@4.12.0"]
  }
}