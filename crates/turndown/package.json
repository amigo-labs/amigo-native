{
  "name": "@amigo-labs/turndown",
  "version": "0.1.0",
  "description": "HTML → Markdown via html5ever. CommonMark + GFM tables/strikethrough out of the box.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "turndown",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^3.23.0",
    "jsdom": "^29.1.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/turndown"
  },
  "keywords": [
    "html",
    "markdown",
    "turndown",
    "gfm",
    "commonmark",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "amigo": {
    "title": "Turndown",
    "description": "HTML → Markdown via html5ever. Ships CommonMark + GFM tables/strikethrough.",
    "tableDescription": "HTML → Markdown, CommonMark + GFM",
    "replaces": "turndown",
    "vsJs": "10-16x",
    "parity": "100%",
    "status": "Subset",
    "competitors": [
      "turndown"
    ]
  }
}
