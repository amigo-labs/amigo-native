{
  "name": "@amigo-labs/tiktoken",
  "version": "0.1.0",
  "description": "Fast BPE tokenizer for OpenAI models — Rust-powered drop-in for tiktoken and gpt-tokenizer",
  "keywords": [
    "tiktoken",
    "gpt-tokenizer",
    "openai",
    "tokenizer",
    "bpe",
    "gpt-4",
    "gpt-4o",
    "cl100k",
    "o200k",
    "native",
    "rust",
    "napi"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "tiktoken",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^3.23.0",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/tiktoken"
  },
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "Tiktoken",
    "category": "text",
    "description": "OpenAI BPE tokenizer powered by tiktoken-rs. Drop-in for tiktoken (WASM) and js-tiktoken.",
    "tableDescription": "OpenAI BPE tokenizer (cl100k, o200k) via `tiktoken-rs`",
    "replaces": "tiktoken/js-tiktoken",
    "vsJs": "0.28-0.31x",
    "parity": "100%",
    "status": "Drop-in",
    "speedup": "3–23× vs tiktoken (WASM) / 2–4× vs js-tiktoken / 0.4× vs gpt-tokenizer",
    "competitors": [
      "tiktoken@1.0.16",
      "js-tiktoken@1.0.15",
      "gpt-tokenizer@2.5.0"
    ]
  }
}
