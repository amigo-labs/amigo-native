{
  "name": "@amigo-labs/xml",
  "version": "0.1.0",
  "description": "Rust-powered SAX-style XML parser via quick-xml",
  "main": "wrapper.js",
  "types": "wrapper.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "wrapper.js",
    "wrapper.d.ts",
    "README.md"
  ],
  "keywords": [
    "xml",
    "sax",
    "parser",
    "native",
    "rust",
    "napi"
  ],
  "napi": {
    "binaryName": "xml",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "bench": "vitest bench",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "@types/sax": "^1.2.7",
    "fast-check": "^3.23.0",
    "sax": "^1.4.1",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/xml"
  },
  "engines": {
    "node": ">= 18"
  }
}
