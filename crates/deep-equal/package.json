{
  "name": "@amigo-labs/deep-equal",
  "version": "0.1.0",
  "description": "Semantic drop-in for fast-deep-equal with a Rust fast-path for plain JSON",
  "main": "wrapper.js",
  "types": "wrapper.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "wrapper.js",
    "wrapper.d.ts",
    "README.md"
  ],
  "keywords": [
    "deep-equal",
    "equal",
    "fast-deep-equal",
    "native",
    "rust",
    "napi"
  ],
  "napi": {
    "binaryName": "deep-equal",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:parity": "vitest run __parity__",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "fast-deep-equal": "^3.1.3",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/deep-equal"
  },
  "engines": {
    "node": ">= 18"
  }
}
