{
  "name": "@amigo-labs/slugify",
  "version": "0.1.0",
  "description": "Blazing fast slugify powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "slugify",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish",
    "test": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/slugify"
  },
  "keywords": [
    "slugify",
    "slug",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "optionalDependencies": {
    "@amigo-labs/slugify-linux-x64-gnu": "0.1.0",
    "@amigo-labs/slugify-linux-x64-musl": "0.1.0",
    "@amigo-labs/slugify-linux-arm64-gnu": "0.1.0",
    "@amigo-labs/slugify-darwin-x64": "0.1.0",
    "@amigo-labs/slugify-darwin-arm64": "0.1.0",
    "@amigo-labs/slugify-win32-x64-msvc": "0.1.0"
  }
}