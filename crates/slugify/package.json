{
  "name": "@amigo-labs/slugify",
  "version": "0.1.0",
  "description": "Blazing fast slugify powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "slugify",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^3.23.0",
    "slugify": "^1.6.6",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/slugify"
  },
  "keywords": [
    "slugify",
    "slug",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "Slugify",
    "category": "text",
    "description": "Unicode-aware slugification. Wraps deunicode + unicode-normalization.",
    "tableDescription": "Unicode-aware slugification via `deunicode`",
    "replaces": "slugify",
    "vsJs": "2.4-5.3x",
    "parity": "—",
    "status": "Alternative",
    "competitors": [
      "slugify@1.6.6"
    ]
  }
}
