{
  "name": "@amigo-labs/sentences",
  "version": "0.1.1",
  "description": "Multi-language sentence boundary detection with an offset-packed zero-copy hot-path.",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_sentences_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_sentences_wasm.d.ts",
        "default": "./wasm/pkg/amigo_sentences_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "wasm/pkg/amigo_sentences_wasm.js",
    "wasm/pkg/amigo_sentences_wasm_bg.js",
    "wasm/pkg/amigo_sentences_wasm_bg.wasm",
    "wasm/pkg/amigo_sentences_wasm.d.ts",
    "wasm/pkg/amigo_sentences_wasm_bg.wasm.d.ts"
  ],
  "napi": {
    "binaryName": "sentences",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^4.8.0",
    "sbd": "^1.0.19",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/sentences"
  },
  "keywords": [
    "nlp",
    "sentence-boundary",
    "sbd",
    "pragmatic-segmenter",
    "tokenize",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "amigo": {
    "title": "Sentences",
    "category": "text",
    "description": "Multi-language sentence boundary detection. String or offset-packed output for hot paths.",
    "tableDescription": "Sentence splitter, multi-language + offset hot-path",
    "replaces": "sbd",
    "vsJs": "TBD",
    "parity": "100%",
    "status": "Compatible",
    "targets": ["node", "browser"],
    "competitors": [
      "sbd"
    ]
  }
}
