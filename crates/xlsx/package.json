{
  "name": "@amigo-labs/xlsx",
  "version": "0.1.1",
  "description": "XLSX read + write via calamine/rust_xlsxwriter. Buffer in, rows out; rows in, Buffer out.",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_xlsx_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_xlsx_wasm.d.ts",
        "default": "./wasm/pkg/amigo_xlsx_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "wasm/pkg/amigo_xlsx_wasm.js",
    "wasm/pkg/amigo_xlsx_wasm_bg.js",
    "wasm/pkg/amigo_xlsx_wasm_bg.wasm",
    "wasm/pkg/amigo_xlsx_wasm.d.ts",
    "wasm/pkg/amigo_xlsx_wasm_bg.wasm.d.ts"
  ],
  "napi": {
    "binaryName": "xlsx",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "exceljs": "^4.4.0",
    "fast-check": "^4.8.0",
    "vitest": "^4.1.6",
    "xlsx": "^0.18.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/xlsx"
  },
  "keywords": [
    "xlsx",
    "excel",
    "spreadsheet",
    "calamine",
    "sheetjs",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "amigo": {
    "title": "XLSX",
    "category": "document",
    "description": "XLSX read + write. Buffer in → rows out, rows in → Buffer out. Single-FFI-crossing.",
    "tableDescription": "XLSX read + write",
    "replaces": "xlsx",
    "vsJs": "2.3-3x",
    "parity": "100%",
    "status": "Subset",
    "targets": ["node", "browser"],
    "competitors": [
      "xlsx",
      "exceljs"
    ]
  }
}
