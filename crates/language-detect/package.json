{
  "name": "@amigo-labs/language-detect",
  "version": "0.1.1",
  "description": "Language detection via whatlang — ISO-639-3 codes out, franc-compatible shape.",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "language-detect",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^4.7.0",
    "franc": "^6.2.0",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/language-detect"
  },
  "keywords": [
    "language",
    "detect",
    "detection",
    "whatlang",
    "franc",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "amigo": {
    "title": "Language Detect",
    "category": "text",
    "description": "Language detection powered by whatlang. Paragraph-size Green, short-string Red by design.",
    "tableDescription": "Language detection via `whatlang`",
    "replaces": "franc",
    "vsJs": "3-16x",
    "parity": "100%",
    "status": "Alternative",
    "competitors": [
      "franc@6.2"
    ]
  }
}
