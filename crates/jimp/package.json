{
  "name": "@amigo-labs/jimp",
  "version": "0.2.0",
  "description": "Scoped v0.1 of jimp — PNG/JPEG decode + encode, resize, crop, flip, rotate, greyscale, brightness, contrast, composite. Via image-rs.",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_jimp_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_jimp_wasm.d.ts",
        "default": "./wasm/pkg/amigo_jimp_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "wasm/pkg/amigo_jimp_wasm.js",
    "wasm/pkg/amigo_jimp_wasm_bg.js",
    "wasm/pkg/amigo_jimp_wasm_bg.wasm",
    "wasm/pkg/amigo_jimp_wasm.d.ts",
    "wasm/pkg/amigo_jimp_wasm_bg.wasm.d.ts"
  ],
  "napi": {
    "binaryName": "jimp",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg && node -e \"require('node:fs').rmSync('pkg/.gitignore',{force:true})\"",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^4.8.0",
    "jimp": "^1.6.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/jimp"
  },
  "keywords": [
    "jimp",
    "image",
    "resize",
    "crop",
    "rotate",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "jimp",
    "category": "document",
    "description": "Scoped jimp port: PNG/JPEG decode/encode + resize + crop + flip + rotate (90° multiples) + greyscale + brightness + contrast + composite, via image-rs.",
    "tableDescription": "Image library (scoped jimp v0.1: PNG/JPEG + 10 ops)",
    "replaces": "jimp",
    "vsJs": "TBD",
    "parity": "scoped-v0.1",
    "status": "Subset",
    "targets": [
      "node",
      "browser"
    ],
    "competitors": [
      "jimp@1.6.0"
    ]
  }
}
