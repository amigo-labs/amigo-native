{
  "name": "@amigo-labs/pngjs",
  "version": "0.1.0",
  "description": "PNG decode/encode via image-rs `png` crate. RGBA output, no native deps in build.",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_pngjs_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_pngjs_wasm.d.ts",
        "default": "./wasm/pkg/amigo_pngjs_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "wasm/pkg/amigo_pngjs_wasm.js",
    "wasm/pkg/amigo_pngjs_wasm_bg.js",
    "wasm/pkg/amigo_pngjs_wasm_bg.wasm",
    "wasm/pkg/amigo_pngjs_wasm.d.ts",
    "wasm/pkg/amigo_pngjs_wasm_bg.wasm.d.ts"
  ],
  "napi": {
    "binaryName": "pngjs",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^4.8.0",
    "pngjs": "^7.0.0",
    "upng-js": "^2.1.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/pngjs"
  },
  "keywords": [
    "png",
    "image",
    "decode",
    "encode",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "pngjs",
    "category": "document",
    "description": "PNG decode/encode to RGBA pixel buffers. Pure-Rust DEFLATE via flate2 + zlib-rs.",
    "tableDescription": "PNG decode/encode (RGBA) via image-rs `png`",
    "replaces": "pngjs",
    "vsJs": "TBD",
    "parity": "rgba-only",
    "status": "Compatible",
    "targets": ["node", "browser"],
    "competitors": [
      "pngjs@7.0.0",
      "upng-js@2.1.0"
    ]
  }
}
