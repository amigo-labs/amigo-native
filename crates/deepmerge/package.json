{
  "name": "@amigo-labs/deepmerge",
  "version": "0.1.1",
  "description": "Semantic drop-in for deepmerge with a Rust fast-path for plain JSON",
  "main": "wrapper.js",
  "types": "wrapper.d.ts",
  "browser": "./wasm/pkg/amigo_deepmerge_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_deepmerge_wasm.d.ts",
        "default": "./wasm/pkg/amigo_deepmerge_wasm.js"
      },
      "default": {
        "types": "./wrapper.d.ts",
        "default": "./wrapper.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "wrapper.js",
    "wrapper.d.ts",
    "README.md",
    "wasm/pkg/amigo_deepmerge_wasm.js",
    "wasm/pkg/amigo_deepmerge_wasm_bg.js",
    "wasm/pkg/amigo_deepmerge_wasm_bg.wasm",
    "wasm/pkg/amigo_deepmerge_wasm.d.ts",
    "wasm/pkg/amigo_deepmerge_wasm_bg.wasm.d.ts"
  ],
  "keywords": [
    "deepmerge",
    "merge",
    "native",
    "rust",
    "napi"
  ],
  "napi": {
    "binaryName": "deepmerge",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg && node -e \"require('node:fs').rmSync('pkg/.gitignore',{force:true})\"",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "bench": "vitest bench",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "test:upstream": "vitest run __conformance__/upstream.spec.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "deepmerge": "^4.3.1",
    "fast-check": "^4.8.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/deepmerge"
  },
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "Deepmerge",
    "category": "util",
    "description": "Recursive object merge for JSON-safe values.",
    "tableDescription": "Recursive object merge",
    "replaces": "deepmerge",
    "vsJs": "3-6.2x",
    "parity": "100%",
    "status": "Compatible",
    "targets": ["node", "browser"],
    "competitors": [
      "deepmerge@4.3.1"
    ]
  }
}
