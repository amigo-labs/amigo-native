{
  "name": "@amigo-labs/pixelmatch",
  "version": "0.3.0",
  "description": "Pixel-level image diff. Rust port of mapbox/pixelmatch — bit-identical output, SIMD-friendly per-pixel loop.",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_pixelmatch_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_pixelmatch_wasm.d.ts",
        "default": "./wasm/pkg/amigo_pixelmatch_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "wasm/pkg/amigo_pixelmatch_wasm.js",
    "wasm/pkg/amigo_pixelmatch_wasm_bg.js",
    "wasm/pkg/amigo_pixelmatch_wasm_bg.wasm",
    "wasm/pkg/amigo_pixelmatch_wasm.d.ts",
    "wasm/pkg/amigo_pixelmatch_wasm_bg.wasm.d.ts"
  ],
  "napi": {
    "binaryName": "pixelmatch",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg && node -e \"require('node:fs').rmSync('pkg/.gitignore',{force:true})\"",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "fast-check": "^4.8.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "vitest": "^4.1.7"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/pixelmatch"
  },
  "keywords": [
    "pixelmatch",
    "image",
    "diff",
    "visual-regression",
    "snapshot",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "pixelmatch",
    "category": "util",
    "description": "Pixel-level RGBA image diff with YIQ delta + anti-aliasing detection, bit-identical to mapbox/pixelmatch.",
    "tableDescription": "Pixel-level image diff (mapbox/pixelmatch parity)",
    "replaces": "pixelmatch",
    "vsJs": "TBD",
    "parity": "strict",
    "status": "Compatible",
    "targets": [
      "node",
      "browser"
    ],
    "competitors": [
      "pixelmatch@7.1.0"
    ]
  }
}
