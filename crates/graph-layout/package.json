{
  "name": "@amigo-labs/graph-layout",
  "version": "0.1.1",
  "description": "Hierarchical (Sugiyama) graph layout — positions and edge routing for directed graphs.",
  "main": "index.js",
  "types": "index.d.ts",
  "browser": "./wasm/pkg/amigo_graph_layout_wasm.js",
  "exports": {
    ".": {
      "browser": {
        "types": "./wasm/pkg/amigo_graph_layout_wasm.d.ts",
        "default": "./wasm/pkg/amigo_graph_layout_wasm.js"
      },
      "default": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "wasm/pkg/amigo_graph_layout_wasm.js",
    "wasm/pkg/amigo_graph_layout_wasm_bg.js",
    "wasm/pkg/amigo_graph_layout_wasm_bg.wasm",
    "wasm/pkg/amigo_graph_layout_wasm.d.ts",
    "wasm/pkg/amigo_graph_layout_wasm_bg.wasm.d.ts"
  ],
  "napi": {
    "binaryName": "graph-layout",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "build:wasm": "cd wasm && wasm-pack build --target bundler --release --out-dir pkg",
    "build:all": "pnpm build && pnpm build:wasm",
    "prepublishOnly": "pnpm build:wasm && napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:wasm": "cd wasm && wasm-pack test --node",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@napi-rs/cli": "^3.7.0",
    "fast-check": "^4.8.0",
    "vitest": "^4.1.8"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/graph-layout"
  },
  "keywords": [
    "graph",
    "layout",
    "sugiyama",
    "dagre",
    "dag",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 18"
  },
  "amigo": {
    "title": "Graph Layout",
    "category": "graph",
    "description": "Hierarchical (Sugiyama-style) DAG layout. Single-call spec → positions + edge routing.",
    "tableDescription": "Hierarchical DAG layout, spec in, positions out",
    "replaces": "dagre",
    "vsJs": "31-66x",
    "parity": "100%",
    "status": "Compatible",
    "targets": ["node", "browser"],
    "competitors": [
      "dagre",
      "@dagrejs/dagre"
    ]
  }
}
