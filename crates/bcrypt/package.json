{
  "name": "@amigo-labs/bcrypt",
  "version": "0.1.0",
  "description": "Fast bcrypt password hashing powered by Rust",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "bcrypt",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi pre-publish --skip-optional-publish --no-gh-release",
    "test": "vitest run __test__",
    "test:conformance": "vitest run __conformance__",
    "test:all": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "fast-check": "^3.23.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amigo-labs/amigo-native",
    "directory": "crates/bcrypt"
  },
  "keywords": [
    "bcrypt",
    "password",
    "hashing",
    "native",
    "rust",
    "napi"
  ],
  "engines": {
    "node": ">= 22"
  },
  "amigo": {
    "title": "Bcrypt",
    "category": "crypto",
    "description": "Bcrypt password hashing with sync + async API. Argon2 sibling.",
    "tableDescription": "Bcrypt password hashing (sync + async)",
    "replaces": "bcrypt/bcryptjs",
    "vsJs": "1.03-1.07x",
    "parity": "100%",
    "status": "Drop-in",
    "competitors": [
      "bcrypt@6.0.0",
      "bcryptjs@2.4.3"
    ]
  }
}
